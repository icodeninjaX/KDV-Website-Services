# Resend API key (create at https://resend.com)
RESEND_API_KEY=

# Inbox that receives new lead notifications
CONTACT_TO_EMAIL=keithvergara1997@gmail.com

# Verified "from" address on Resend (must own the domain). Fallback: onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Tawk.to live chat — leave both blank to disable the widget entirely.
# Property ID is the 24-char string in the embed URL; widget ID defaults to "default".
# Find both at https://dashboard.tawk.to → Administration → Channels → Chat Widget.
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=default
