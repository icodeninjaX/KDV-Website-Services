# =============================================================================
# .gitignore — KDV Website Services
# =============================================================================
# Philosophy: ignore aggressively, allow-list explicitly.
# If a secret or build artifact slips into git history once, it stays forever.
# When in doubt, ignore it. You can always `git add -f` a single tracked file.
# =============================================================================


# -----------------------------------------------------------------------------
# DEPENDENCIES
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz


# -----------------------------------------------------------------------------
# BUILD OUTPUT
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/
*.tsbuildinfo

# Auto-generated by Next.js on every dev/build — never edit by hand
next-env.d.ts


# -----------------------------------------------------------------------------
# CACHES
# -----------------------------------------------------------------------------
.cache/
.eslintcache
.swc/
.turbo/
.parcel-cache/
.next/cache/


# -----------------------------------------------------------------------------
# TESTING / COVERAGE
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov


# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------
# Rule: NEVER commit any .env* file. .env.example is the only tracked template.
# If you ever paste a real key into .env.example by mistake, rotate it immediately.
.env
.env.*
!.env.example


# -----------------------------------------------------------------------------
# SECRETS / CREDENTIALS
# -----------------------------------------------------------------------------
# Catch common secret-file patterns before they get committed.
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# Generic secret files
secrets/
.secret
.secrets
secret.json
secrets.json
secret*.json
secrets*.json

# Common credential payloads
credentials.json
service-account*.json
firebase-adminsdk*.json
*-adminsdk.json

# SSH keys
id_rsa
id_rsa.*
id_dsa
id_ecdsa
id_ed25519
*.ppk


# -----------------------------------------------------------------------------
# DEPLOYMENT / HOSTING
# -----------------------------------------------------------------------------
.vercel/
.netlify/


# -----------------------------------------------------------------------------
# ERROR / ANALYTICS TOOLING
# -----------------------------------------------------------------------------
.sentryclirc


# -----------------------------------------------------------------------------
# IDE / EDITORS
# -----------------------------------------------------------------------------
# VS Code: ignore everything except shared extension recommendations.
.vscode/*
!.vscode/extensions.json

# JetBrains
.idea/

# Sublime
*.sublime-project
*.sublime-workspace

# Vim / Emacs / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# VS Code Local History extension
.history/


# -----------------------------------------------------------------------------
# AI TOOLING (per-developer / per-machine — never shared)
# -----------------------------------------------------------------------------
.claude/
.cursor/
.aider*
.windsurf/
.playwright-mcp/

# Per-developer Claude memory file (CLAUDE.md is shared, CLAUDE.local.md is private)
CLAUDE.local.md


# -----------------------------------------------------------------------------
# OS-SPECIFIC JUNK
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# Linux
.directory
.Trash-*


# -----------------------------------------------------------------------------
# TEMP / SCRATCH
# -----------------------------------------------------------------------------
*.tmp
*.temp
tmp/
temp/
*.bak
*.backup
*.orig

# Source screenshots — converted to WebP under public/portfolio/
images/

# Compressed archives in the repo root usually mean a temp drop
/*.zip
/*.tar
/*.tar.gz
/*.tgz
/*.rar
/*.7z
